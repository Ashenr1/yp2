<UserControl x:Class="UP02.Elements.ItemNetworkSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TestButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" Margin="10" Padding="15" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="Equipment" Text="{Binding Equipment.Name}" FontWeight="Bold" FontSize="15" Foreground="#0060AC" Margin="0,0,0,10"/>

                <StackPanel Style="{StaticResource InfoRowStyle}">
                    <TextBlock Text="🌐 IP адрес:" FontSize="13" Foreground="#0060AC" FontWeight="SemiBold" Width="100"/>
                    <TextBlock x:Name="IPAddress" Text="{Binding IPAddress}" FontSize="13" Foreground="#333"/>
                </StackPanel>
                <StackPanel Style="{StaticResource InfoRowStyle}">
                    <TextBlock Text="🔢 Маска сети:" FontSize="13" Foreground="#0060AC" FontWeight="SemiBold" Width="100"/>
                    <TextBlock x:Name="SubnetMask" Text="{Binding SubnetMask}" FontSize="13" Foreground="#333"/>
                </StackPanel>
                <StackPanel Style="{StaticResource InfoRowStyle}">
                    <TextBlock Text="🚪 Шлюз:" FontSize="13" Foreground="#0060AC" FontWeight="SemiBold" Width="100"/>
                    <TextBlock x:Name="Gateway" Text="{Binding Gateway}" FontSize="13" Foreground="#333"/>
                </StackPanel>
                <StackPanel Style="{StaticResource InfoRowStyle}">
                    <TextBlock Text="🌍 DNS сервер:" FontSize="13" Foreground="#0060AC" FontWeight="SemiBold" Width="100"/>
                    <TextBlock x:Name="DNSServer" Text="{Binding DNSServers}" FontSize="13" Foreground="#333"/>
                </StackPanel>

                <Button x:Name="CheckConnectionButton" Style="{StaticResource TestButtonStyle}" Content="🔍 Проверить соединение" Click="CheckConnection"/>
                <ProgressBar x:Name="ConnectionProgressBar" IsIndeterminate="True" Visibility="Collapsed" Height="4" Margin="0,8,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Click="DeleteClick" Background="#9EA1A2" Style="{StaticResource IconButtonStyle}" ToolTip="Удалить" VerticalAlignment="Center">
                <TextBlock Text="🗑"/>
            </Button>
            <Button Grid.Column="2" Click="UpdateClick" Background="#0060AC" Style="{StaticResource IconButtonStyle}" ToolTip="Редактировать" VerticalAlignment="Center">
                <TextBlock Text="✏"/>
            </Button>
        </Grid>
    </Border>
</UserControl>