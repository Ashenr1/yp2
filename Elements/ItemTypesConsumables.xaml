<UserControl x:Class="UP02.Elements.ItemTypesConsumables"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" Margin="10" Padding="15" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="📦" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TypeLb" Text="{Binding Type}" FontSize="15" Foreground="#0060AC" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Column="1" x:Name="CharacteristisDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MaxHeight="180" BorderBrush="#E0E0E0" BorderThickness="1" RowHeight="28">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="📋 Характеристики" Binding="{Binding CharacteristicName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Click="DeleteClick" Background="#9EA1A2" Style="{StaticResource IconButtonStyle}" ToolTip="Удалить">
                    <TextBlock Text="🗑"/>
                </Button>
                <Button Click="UpdateClick" Background="#0060AC" Style="{StaticResource IconButtonStyle}" ToolTip="Редактировать">
                    <TextBlock Text="✏"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>