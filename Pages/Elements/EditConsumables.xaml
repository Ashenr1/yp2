<Page x:Class="UP02.Pages.Elements.EditConsumables"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="EditConsumables"
      d:DesignHeight="700" d:DesignWidth="550">

    <Page.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImageSelectButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🖼 " FontSize="14"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0060AC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="#9EA1A2" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="#9EA1A2" BorderThickness="1">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                    <Border Background="White" BorderBrush="#9EA1A2" BorderThickness="1" CornerRadius="8" Margin="0,2,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#9EA1A2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9EA1A2" Offset="0.0"/>
            <GradientStop Color="#D0D0D0" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border CornerRadius="15" Background="White" Padding="30,25" Width="560" MaxHeight="750">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#0060AC" CornerRadius="10" Height="60" Margin="0,0,0,20">
                    <TextBlock Text="📦 Редактирование расходника" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Content="Выбрать картинку" Style="{StaticResource ImageSelectButtonStyle}" Click="SelectAndSaveImage_Click"/>

                        <TextBlock Text="Наименование" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="NameTB" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Описание" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="DescriptionTB" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Дата поступления" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ReceiptDateTB" Style="{StaticResource TextBoxStyle}" ToolTip="ГГГГ-ММ-ДД"/>

                        <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="QuantityTB" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Ответственный" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ResponsibleUserCB" Style="{StaticResource ComboBoxStyle}"/>

                        <TextBlock Text="Временный ответственный" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="TempResponsibleUserCB" Style="{StaticResource ComboBoxStyle}"/>

                        <TextBlock Text="Тип" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="TypesConsumablesCB" Style="{StaticResource ComboBoxStyle}" SelectionChanged="TypesConsumablesCB_Changed"/>

                        <TextBlock Text="📋 Характеристики" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,5"/>
                        <DataGrid x:Name="CharacteristisDG">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Название характеристики" Binding="{Binding CharacteristicName}" Width="*"/>
                                <DataGridTextColumn Header="Значение характеристики" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Click="SaveChangesClick" Background="#0060AC" Style="{StaticResource ActionButtonStyle}" ToolTip="Сохранить">
                        <TextBlock Text="✓" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    </Button>
                    <Button Click="UndoСhangesClick" Background="#9EA1A2" Style="{StaticResource ActionButtonStyle}" ToolTip="Отмена">
                        <TextBlock Text="✗" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>