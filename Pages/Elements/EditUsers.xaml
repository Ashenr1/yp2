<Page x:Class="UP02.Pages.Elements.EditUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="EditUsers"
      d:DesignHeight="600" d:DesignWidth="450">

    <Page.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0060AC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="#9EA1A2" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="#9EA1A2" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border CornerRadius="8" Background="White" BorderBrush="#9EA1A2" BorderThickness="1">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                    <Border Background="White" BorderBrush="#9EA1A2" BorderThickness="1" CornerRadius="8" Margin="0,2,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9EA1A2" Offset="0.0"/>
            <GradientStop Color="#D0D0D0" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border CornerRadius="15" Background="White" Padding="30,25" Width="400" MaxHeight="650">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.25"/>
            </Border.Effect>
            <Grid>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="#0060AC" CornerRadius="10" Height="55" Margin="0,0,0,15">
                    <TextBlock Text="👥 Редактирование пользователя" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="LastName" Style="{StaticResource TextBoxStyle}"/>
                        <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="FirstName" Style="{StaticResource TextBoxStyle}"/>
                        <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="MiddleName" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Роль" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="Role" Style="{StaticResource ComboBoxStyle}" SelectedValuePath="Content">
                            <ComboBoxItem>Администратор</ComboBoxItem>
                            <ComboBoxItem>Преподаватель</ComboBoxItem>
                            <ComboBoxItem>Сотрудник</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="Логин" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="Login" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="Password" Style="{StaticResource PasswordBoxStyle}"/>

                        <TextBlock Text="Электронная почта" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="Email" Style="{StaticResource TextBoxStyle}"/>

                        <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="Phone" Style="{StaticResource TextBoxStyle}"/>
                        <TextBlock Text="Адрес" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="Address" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Click="SaveChangesClick" Background="#0060AC" Style="{StaticResource ActionButtonStyle}" ToolTip="Сохранить">
                        <TextBlock Text="✓"/>
                    </Button>
                    <Button Click="UndoСhangesClick" Background="#9EA1A2" Style="{StaticResource ActionButtonStyle}" ToolTip="Отмена">
                        <TextBlock Text="✗"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>