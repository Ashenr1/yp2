<Page x:Class="UP02.Pages.Main.PageAuthorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP02.Pages.Main"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="AuthButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="320"/>
            <Setter Property="Margin" Value="5,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E41613"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9EA1A2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AuthTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="350"/>
            <Setter Property="Margin" Value="5,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" 
                                Background="White" 
                                BorderBrush="#9EA1A2" 
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="350"/>
            <Setter Property="Margin" Value="5,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="8" 
                                Background="White" 
                                BorderBrush="#9EA1A2" 
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          VerticalAlignment="Center" 
                                          Margin="15,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthLabelStyle" TargetType="Label">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,5,5,2"/>
        </Style>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9EA1A2" Offset="0.0"/>
            <GradientStop Color="#D0D0D0" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Border CornerRadius="15" 
                Background="White" 
                Width="480" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  ShadowDepth="3" 
                                  Opacity="0.25"/>
            </Border.Effect>

            <StackPanel Margin="40">
                <Border Background="#0060AC" 
                        CornerRadius="10" 
                        Height="80" 
                        Margin="0,0,0,20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔐 Добро пожаловать!" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Войдите в систему" 
                                   FontSize="13" 
                                   Foreground="White" 
                                   Opacity="0.8" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Label Style="{StaticResource AuthLabelStyle}" 
                       Content="📧 Логин"/>
                <TextBox x:Name="LoginUser" 
                         Style="{StaticResource AuthTextBoxStyle}" 
                         ToolTip="Введите ваш логин"/>

                <Label Style="{StaticResource AuthLabelStyle}" 
                       Content="🔒 Пароль"/>
                <PasswordBox x:Name="PasswordUser" 
                             Style="{StaticResource AuthPasswordBoxStyle}" 
                             ToolTip="Введите ваш пароль"/>

                <Button Style="{StaticResource AuthButtonStyle}" 
                        Background="#0060AC" 
                        Content="▶ ВОЙТИ" 
                        Click="Authorization_Click" 
                        Margin="5,20,5,5"/>

                <Button Style="{StaticResource AuthButtonStyle}" 
                        Background="#9EA1A2" 
                        Content="⚙ НАСТРОЙКИ ПОДКЛЮЧЕНИЯ" 
                        Click="OpenConnectionSettings_Cick" 
                        Margin="5,5,5,15"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>